{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@zillow/shared-types": ["packages/shared-types/src"],
      "@zillow/shared-utils": ["packages/shared-utils/src"],
      "@zillow/shared-config": ["packages/shared-config/src"],
      "@zillow/shared-db": ["packages/shared-db/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", "coverage"]
}









